<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/color_primary_blue">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="8dp">
        <TextView
            android:id="@+id/tv_title_lichthi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8.5dp"
            android:text="QUẢN LÝ LỊCH THI"
            android:textAlignment="center"
            android:textColor="@color/color_primary_blue_dark"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@color/white" />
    </androidx.cardview.widget.CardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_filter_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BỘ LỌC DANH SÁCH"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignMargins">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_margin="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Môn học"
                                android:textSize="12sp"
                                android:textColor="#666666"
                                android:paddingStart="4dp"/>
                            <Spinner android:id="@+id/spinner_filter_mon" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/btn_dropdown"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_margin="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phòng học"
                                android:textSize="12sp"
                                android:textColor="#666666"
                                android:paddingStart="4dp"/>
                            <Spinner android:id="@+id/spinner_filter_phong" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/btn_dropdown"/>
                        </LinearLayout>

                        <Button android:id="@+id/btn_filter_lichthi"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_gravity="bottom"
                            android:layout_margin="4dp"
                            android:text="LỌC"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/color_secondary_teal" />

                        <Button android:id="@+id/btn_refresh_lichthi"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_gravity="bottom"
                            android:layout_margin="4dp"
                            android:text="LÀM MỚI"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/color_primary_blue" />
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_search_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÌM KIẾM NHANH"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <EditText
                        android:id="@+id/et_search_lichthi"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="54dp"
                        android:hint="Tìm kỳ thi hoặc môn học..."
                        android:textSize="18sp"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp"/>

                    <Button
                        android:id="@+id/btn_search_lichthi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TÌM"
                        android:textSize="18sp"
                        android:backgroundTint="@color/color_primary_blue" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_list_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DANH SÁCH CHI TIẾT"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="24dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/color_primary_blue_dark"
                            android:padding="12dp">
                            <TextView android:layout_width="150dp" android:layout_height="wrap_content" android:text="Tên Kỳ Thi" android:textColor="@color/white" android:textStyle="bold" android:gravity="center" android:textSize="16sp"/>
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Môn Học" android:textColor="@color/white" android:textStyle="bold" android:gravity="center" android:textSize="16sp"/>
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Ngày Thi" android:textColor="@color/white" android:textStyle="bold" android:gravity="center" android:textSize="16sp"/>
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Thời Gian" android:textColor="@color/white" android:textStyle="bold" android:gravity="center" android:textSize="16sp"/>
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Phòng" android:textColor="@color/white" android:textStyle="bold" android:gravity="center" android:textSize="16sp"/>
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_lichthi"
                            android:layout_width="wrap_content"
                            android:layout_height="300dp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_update_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CẬP NHẬT LỊCH THI"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_update"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tên kỳ thi" android:textSize="16sp" android:textColor="#666666"/>
                    <EditText android:id="@+id/et_form_tenkythi" android:layout_width="match_parent" android:layout_height="54dp" android:textSize="20sp" android:textStyle="bold" android:hint="Nhập tên kỳ thi..."/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignMargins"
                        android:layout_marginTop="16dp">

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="4dp">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Môn học" android:textSize="16sp" android:textColor="#666666"/>
                            <Spinner android:id="@+id/spinner_form_mon" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/btn_dropdown"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="4dp">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Phòng học" android:textSize="16sp" android:textColor="#666666"/>
                            <Spinner android:id="@+id/spinner_form_phong" android:layout_width="match_parent" android:layout_height="48dp" android:background="@android:drawable/btn_dropdown"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="4dp">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ngày thi" android:textSize="16sp" android:textColor="#666666"/>
                            <EditText android:id="@+id/et_form_ngaythi" android:layout_width="match_parent" android:layout_height="54dp" android:focusable="false" android:textSize="18sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="4dp">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Giờ bắt đầu" android:textSize="16sp" android:textColor="#666666"/>
                            <EditText android:id="@+id/et_form_giobd" android:layout_width="match_parent" android:layout_height="54dp" android:focusable="false" android:textSize="18sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:orientation="vertical" android:padding="4dp">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Giờ kết thúc" android:textSize="16sp" android:textColor="#666666"/>
                            <EditText android:id="@+id/et_form_giokt" android:layout_width="match_parent" android:layout_height="54dp" android:focusable="false" android:textSize="18sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </GridLayout>

                    <Button
                        android:id="@+id/btn_save_lichthi"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="20dp"
                        android:text="LƯU DỮ LIỆU"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:backgroundTint="@color/color_secondary_teal" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <Button
                            android:id="@+id/btn_add_lichthi"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="54dp"
                            android:text="THÊM MỚI"
                            android:textSize="16sp"
                            android:backgroundTint="@color/color_primary_blue"
                            android:layout_marginEnd="4dp"/>

                        <Button
                            android:id="@+id/btn_delete_lichthi"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="54dp"
                            android:text="XÓA"
                            android:textSize="16sp"
                            android:backgroundTint="#F44336"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_export_excel_lichthi"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="12dp"
                        android:text="XUẤT EXCEL"
                        android:textSize="20sp"
                        android:backgroundTint="@color/color_primary_blue_dark" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
