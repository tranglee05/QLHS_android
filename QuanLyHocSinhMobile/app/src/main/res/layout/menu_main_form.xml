<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/color_primary_blue">

    <!-- Header Title -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="HỆ THỐNG QUẢN LÝ HỌC SINH"
            android:textAlignment="center"
            android:textColor="@color/color_primary_blue_dark"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@color/white" />

    </androidx.cardview.widget.CardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical"
        android:scrollbarStyle="outsideOverlay"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- NHÓM 1: HỒ SƠ & CƠ CẤU -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. HỒ SƠ &amp; CƠ CẤU"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <Button android:id="@+id/btn_lop_hoc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="LỚP HỌC" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_giao_vien" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="GIÁO VIÊN" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_to_bo_mon" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="TỔ BỘ MÔN" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NHÓM 2: ĐÀO TẠO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. ĐÀO TẠO"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <Button android:id="@+id/btn_mon_hoc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="MÔN HỌC" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_lich_day" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="LỊCH DẠY" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_thiet_bi" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="THIẾT BỊ" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NHÓM 3: KHẢO THÍ & KẾT QUẢ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. KHẢO THÍ &amp; KẾT QUẢ"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <Button android:id="@+id/btn_diem_so" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ĐIỂM SỐ" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_hanh_kiem" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="HẠNH KIỂM" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_lich_thi" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="LỊCH THI" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NHÓM 4: HÀNH CHÍ & TÀI VỤ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4. HÀNH CHÍNH &amp; TÀI VỤ"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <Button android:id="@+id/btn_hoc_phi" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="HỌC PHÍ" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_thong_bao" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="THÔNG BÁO" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_phuc_khao" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PHÚC KHẢO" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NHÓM 5: HỆ THỐNG & CHÍNH SÁCH -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5. HỆ THỐNG &amp; CHÍNH SÁCH"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <Button android:id="@+id/btn_ho_so_hs" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="HỒ SƠ HS" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_tai_khoan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="TÀI KHOẢN" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_chinh_sach" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CHÍNH SÁCH" android:textColor="@color/color_primary_blue" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />
                    <Button android:id="@+id/btn_dang_xuat" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ĐĂNG XUẤT" android:textColor="#D21919" android:textSize="20sp" android:gravity="start|center_vertical" android:paddingStart="20dp" android:background="@android:color/transparent" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
