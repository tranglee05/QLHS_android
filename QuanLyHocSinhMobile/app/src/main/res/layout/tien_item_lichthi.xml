<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/border_bottom">

    <TextView
        android:id="@+id/tv_tenkythi"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:text="Học kỳ 1"
        android:gravity="start"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_mon"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="Toán học"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_ngaythi"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="20/12/2023"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_thoigian"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="07:30 - 09:00"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_phong"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="Phòng 101"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="14sp" />

</LinearLayout>