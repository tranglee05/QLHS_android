        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_1tiet"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="8.6"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_gk"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="9.8"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_ck"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:text="3.3"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_tk"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:text="6.53"
        android:gravity="center"
        android:textStyle="bold"
        android:textColor="@color/color_primary_blue_dark"
        android:textSize="14sp" />

</LinearLayout>